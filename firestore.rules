rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuth() { return request.auth != null; }
    function me() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isAdmin() { return isAuth() && me().role == 'admin'; }
    function isTeacher() { return isAuth() && me().role == 'teacher'; }
    function isStudent() { return isAuth() && me().role == 'student'; }
    function isApprovedTeacher() { return isTeacher() && me().isApproved == true; }
    function isApprovedStudent() { return isStudent() && me().enrollmentStatus == 'APPROVED'; }
    function isOwner(uid) { return isAuth() && request.auth.uid == uid; }
    function touchesProtectedField(fields) { return request.resource.data.diff(resource.data).affectedKeys().hasAny(fields); }
    function teacherOwnsCourse(courseId) { return get(/databases/$(database)/documents/courses/$(courseId)).data.teacherId == request.auth.uid; }
    function studentMatchesTarget(notifData) {
      let e = me();
      return notifData.targetDepartmentId == e.departmentId &&
        (notifData.targetYear == null || notifData.targetYear == e.currentYear) &&
        (notifData.targetSemesterId == null || notifData.targetSemesterId == e.currentSemesterId);
    }

    // Collections
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuth() && isOwner(userId) && request.resource.data.role != 'admin' && (
        (request.resource.data.role == 'student' && request.resource.data.enrollmentStatus == 'NONE') ||
        (request.resource.data.role == 'teacher' && request.resource.data.isApproved == false)
      );
      allow update: if isAdmin() || (isOwner(userId) && !touchesProtectedField(['role','isApproved','email','enrollmentStatus','rollNumber','departmentId','programId','batchYear','currentYear','currentSemesterId']));
      allow delete: if isAdmin();
    }
    match /users/{userId} {
      allow list: if isAdmin() || (isApprovedTeacher() && resource.data.role == 'student');
    }

    match /enrollmentRequests/{reqId} {
      allow read: if isAuth() && (resource.data.studentId == request.auth.uid || isAdmin());
      allow create: if isStudent() && request.resource.data.studentId == request.auth.uid && request.resource.data.status == 'PENDING' && me().enrollmentStatus == 'NONE';
      allow update, delete: if isAdmin();
    }

    match /departments/{deptId} { allow read: if isAuth(); allow write: if isAdmin(); }
    match /programs/{progId} { allow read: if isAuth(); allow write: if isAdmin(); }
    match /semesters/{semId} { allow read: if isAuth(); allow write: if isAdmin(); }
    match /courses/{courseId} {
      allow read: if isAuth();
      allow create: if isAdmin();
      allow update: if isAdmin() || (isApprovedTeacher() && resource.data.teacherId == request.auth.uid && !touchesProtectedField(['teacherId', 'departmentId', 'programId', 'semesterId', 'creditHours']));
      allow delete: if isAdmin();
    }

    match /courseEnrollments/{enrollId} {
      allow read: if isAuth() && (resource.data.studentId == request.auth.uid || isAdmin() || (isApprovedTeacher() && teacherOwnsCourse(resource.data.courseId)));
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isApprovedTeacher() && teacherOwnsCourse(resource.data.courseId));
    }

    match /attendance/{attId} {
      allow read: if isAuth() && (resource.data.studentId == request.auth.uid || isAdmin() || (isApprovedTeacher() && resource.data.teacherId == request.auth.uid));
      allow create: if isAdmin() || (isApprovedTeacher() && request.resource.data.teacherId == request.auth.uid && teacherOwnsCourse(request.resource.data.courseId));
      allow update: if isAdmin() || (isApprovedTeacher() && resource.data.teacherId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /results/{resultId} {
      allow read: if isAdmin() || (isApprovedTeacher() && resource.data.teacherId == request.auth.uid) || (isApprovedStudent() && resource.data.studentId == request.auth.uid && resource.data.isPublished == true);
      allow create: if isAdmin() || (isApprovedTeacher() && request.resource.data.teacherId == request.auth.uid && teacherOwnsCourse(request.resource.data.courseId) && request.resource.data.attendanceMarks <= 10 && request.resource.data.assignmentMarks <= 10 && request.resource.data.midMarks <= 30 && request.resource.data.finalMarks <= 50 && request.resource.data.isPublished == false);
      allow update: if isAdmin() || (isApprovedTeacher() && resource.data.teacherId == request.auth.uid && !touchesProtectedField(['isPublished', 'publishedAt']) && request.resource.data.attendanceMarks <= 10 && request.resource.data.assignmentMarks <= 10 && request.resource.data.midMarks <= 30 && request.resource.data.finalMarks <= 50);
      allow delete: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isAdmin() || isApprovedTeacher() || (isApprovedStudent() && studentMatchesTarget(resource.data));
      allow create: if isAdmin() || (isApprovedTeacher() && request.resource.data.createdBy == request.auth.uid && request.resource.data.targetDepartmentId == me().departmentId);
      allow update: if isAdmin() || (isApprovedTeacher() && resource.data.createdBy == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /challans/{challanId} {
      allow read: if isAdmin() || (isAuth() && resource.data.studentId == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    match /challanBulkJobs/{jobId} { allow read, write: if isAdmin(); }

    match /assignments/{assignId} {
      allow read: if isAuth();
      allow create: if isAdmin() || (isApprovedTeacher() && request.resource.data.teacherId == request.auth.uid && teacherOwnsCourse(request.resource.data.courseId));
      allow update, delete: if isAdmin() || (isApprovedTeacher() && resource.data.teacherId == request.auth.uid);
    }

    match /assignmentSubmissions/{subId} {
      allow read: if isAdmin() || (isApprovedTeacher() && teacherOwnsCourse(resource.data.courseId)) || (isApprovedStudent() && resource.data.studentId == request.auth.uid);
      allow create: if isApprovedStudent() && request.resource.data.studentId == request.auth.uid;
      allow update: if isAdmin() || (isApprovedTeacher() && teacherOwnsCourse(resource.data.courseId)) || (isApprovedStudent() && resource.data.studentId == request.auth.uid && !touchesProtectedField(['marks', 'feedback', 'isGraded']));
      allow delete: if isAdmin();
    }

    match /materials/{matId} {
      allow read: if isAuth();
      allow create: if isAdmin() || (isApprovedTeacher() && request.resource.data.teacherId == request.auth.uid && teacherOwnsCourse(request.resource.data.courseId));
      allow update, delete: if isAdmin() || (isApprovedTeacher() && resource.data.teacherId == request.auth.uid);
    }

    match /timetable/{slotId} { allow read: if isAuth(); allow write: if isAdmin(); }
    match /scholarships/{schId} { allow read: if isAuth(); allow write: if isAdmin(); }

    match /scholarshipApplications/{appId} {
      allow read: if isAdmin() || (isApprovedStudent() && resource.data.studentId == request.auth.uid);
      allow create: if isApprovedStudent() && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /library/{bookId} { allow read: if isAuth(); allow write: if isAdmin(); }
    match /settings/{settingId} { allow read: if isAuth(); allow write: if isAdmin(); }

    match /virtualClasses/{classId} {
      allow read: if isAuth();
      allow create: if isAdmin() || (isApprovedTeacher() && request.resource.data.teacherId == request.auth.uid && teacherOwnsCourse(request.resource.data.courseId));
      allow update, delete: if isAdmin() || (isApprovedTeacher() && resource.data.teacherId == request.auth.uid);
    }
  }
}
